# Simple JSON file DB server
FROM node:22-alpine

WORKDIR /app

# System deps for compiling node-canvas (cairo/pango bindings) on musl/Alpine —
# used to render the portfolio chart image sent by the Telegram bot.
RUN apk add --no-cache \
    build-base g++ python3 pkgconfig \
    cairo-dev pango-dev jpeg-dev giflib-dev librsvg-dev pixman-dev freetype-dev fontconfig

# Only need express + canvas (server-side portfolio chart rendering)
RUN npm init -y && npm install express canvas

COPY server/db-server.js ./index.js
COPY server/telegram-bot.js ./telegram-bot.js
COPY server/canvasTheme.js ./canvasTheme.js
COPY server/portfolioChart.js ./portfolioChart.js
COPY server/pendingChart.js ./pendingChart.js
COPY server/budgetChart.js ./budgetChart.js
COPY server/bankSync.js ./bankSync.js
COPY server/backup.js ./backup.js
COPY server/fonts ./fonts

# Data directory will be mounted as a volume
RUN mkdir -p /data

EXPOSE 3000

CMD ["node", "index.js"]
